{
  "name": "@accordproject/cicero-core",
  "version": "2.1.0",
  "description": "Cicero Core - Implementation of Accord Protocol Template Specification",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "type": "commonjs",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib",
    "umd"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "browser": "umd/cicero-core.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "webpack": "webpack --config webpack.config.js --mode production",
    "build:dist": "npm run build && npm run webpack",
    "clean": "rimraf lib umd",
    "prepublishOnly": "npm run build:dist",
    "pretest": "npm run lint && npm run build",
    "lint": "eslint . --ext .ts",
    "postlint": "npm run licchk",
    "licchk": "license-check-and-add check -f ./header.config.json",
    "test": "jest --silent",
    "test:noisy": "jest",
    "test:watch": "jest --watch",
    "test:updateSnapshot": "jest --updateSnapshot --silent",
    "test:cov": "npm run lint && npm run build && jest --coverage --silent",
    "jsdoc": "jsdoc -c jsdoc.json package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/accordproject/template-archive.git",
    "directory": "packages/cicero-core"
  },
  "keywords": [
    "accord",
    "cicero",
    "smart",
    "contract"
  ],
  "author": "accordproject.org",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/accordproject/template-archive/issues"
  },
  "homepage": "https://github.com/accordproject/template-archive",
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/jest": "^29.5.12",
    "@types/json-stable-stringify": "^1.0.36",
    "@types/node": "^20.11.30",
    "@types/node-forge": "^1.3.11",
    "archiver": "5.3.1",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "3.12.0",
    "eslint": "8.57.1",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "license-check-and-add": "4.0.5",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "rimraf": "^5.0.5",
    "source-map-loader": "^5.0.0",
    "stream-browserify": "3.0.0",
    "ts-jest": "^29.1.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.9.3",
    "webpack": "5.104.1",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@accordproject/concerto-core": "4.1.4",
    "@accordproject/concerto-util": "4.1.4",
    "@accordproject/markdown-cicero": "1.0.1",
    "@accordproject/markdown-common": "1.0.1",
    "@accordproject/markdown-template": "1.0.1",
    "@accordproject/markdown-transform": "1.0.1",
    "axios": "1.15.0",
    "debug": "4.3.4",
    "ietf-language-tag-regex": "0.0.5",
    "json-stable-stringify": "1.0.2",
    "jszip": "3.10.1",
    "node-cache": "5.1.2",
    "node-forge": "^1.4.0",
    "semver": "7.5.3",
    "slash": "3.0.0",
    "xregexp": "5.1.1"
  },
  "peerDependencies": {
    "@accordproject/concerto-core": "^4.1.3"
  }
}
