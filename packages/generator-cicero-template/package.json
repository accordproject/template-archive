{
  "name": "@accordproject/generator-cicero-template",
  "version": "1.0.0",
  "description": "Code generator for a Cicero Template",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "clause.io",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf generators/app/*.js generators/app/*.js.map generators/app/*.d.ts",
    "lint": "eslint . --ext .ts",
    "postlint": "npm run licchk",
    "licchk": "license-check-and-add check -f ./license.config.json",
    "pretest": "npm run lint && npm run build",
    "test": "jest --silent",
    "test:noisy": "jest",
    "test:cov": "npm run lint && npm run build && jest --coverage --silent"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/accordproject/template-archive.git",
    "directory": "packages/generator-cicero-template"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/accordproject/template-archive/issues"
  },
  "homepage": "https://github.com/accordproject/template-archive#readme",
  "files": [
    "generators"
  ],
  "main": "generators/app/index.js",
  "keywords": [
    "cicero",
    "template",
    "smart contracts",
    "clause",
    "accord project",
    "yeoman-generator"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/yeoman-assert": "^3.1.4",
    "@types/yosay": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "eslint": "8.57.1",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "license-check-and-add": "4.0.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3",
    "yeoman-assert": "3.1.1",
    "yeoman-test": "6.3.0"
  },
  "dependencies": {
    "chalk": "4.1.2",
    "yeoman-generator": "^5.9.0",
    "yosay": "2.0.2"
  }
}
