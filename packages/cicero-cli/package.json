{
  "name": "@accordproject/cicero-cli",
  "version": "1.0.0",
  "description": "Cicero CLI",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cicero": "lib/cli.js"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf lib",
    "lint": "eslint . --ext .ts",
    "postlint": "npm run licchk",
    "licchk": "license-check-and-add check -f ./license.config.json",
    "pretest": "npm run lint && npm run build",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --silent",
    "test:noisy": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:cov": "npm run lint && npm run build && cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --silent"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/accordproject/template-archive.git",
    "directory": "packages/cicero-cli"
  },
  "keywords": [
    "clause",
    "legal",
    "tech"
  ],
  "author": "Accord Project",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/accordproject/template-archive/issues"
  },
  "homepage": "https://www.accordproject.org/projects/cicero",
  "dependencies": {
    "@accordproject/cicero-core": "1.0.0",
    "@accordproject/concerto-codegen": "^4.0.1",
    "@accordproject/concerto-util": "^4.0.3",
    "@accordproject/template-engine": "^3.0.1",
    "mkdirp": "3.0.1",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "cross-env": "^7.0.3",
    "eslint": "8.57.1",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.2",
    "license-check-and-add": "4.0.5",
    "rimraf": "^5.0.5",
    "tmp-promise": "3.0.3",
    "ts-jest": "^29.1.2",
    "typescript": "^5.9.3"
  }
}
